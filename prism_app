<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prism - AI Business Intelligence</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        brand: { 50: '#f0f9ff', 100: '#e0f2fe', 500: '#0ea5e9', 600: '#0284c7', 900: '#0c4a6e' }
                    }
                }
            }
        }
    </script>
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Marked.js for Markdown parsing -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <!-- Chart.js for Dashboards -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- PDF.js for text extraction and rendering -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <!-- PptxGenJS for PowerPoint generation and downloads -->
    <script src="https://cdn.jsdelivr.net/npm/pptxgenjs@3.12.0/dist/pptxgen.bundle.js"></script>
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <style>
        body { font-family: 'Inter', sans-serif; overflow: hidden; }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        .dark ::-webkit-scrollbar-thumb { background: #475569; }
        
        /* Markdown Styles inside prose content */
        .prose h1, .prose h2, .prose h3 { font-weight: 600; margin-top: 1.5em; margin-bottom: 0.5em; color: inherit; }
        .prose h1 { font-size: 1.5rem; } .prose h2 { font-size: 1.25rem; }
        .prose p { margin-bottom: 1em; line-height: 1.6; color: inherit; }
        .prose ul { list-style-type: disc; padding-left: 1.5em; margin-bottom: 1em; color: inherit;}
        .prose strong { font-weight: 600; color: inherit; }
        
        /* Clean and Spacious Report Table Layouts */
        .prose table {
            width: 100%;
            margin: 1.5rem 0;
            border-collapse: separate;
            border-spacing: 0;
            font-size: 0.825rem;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
        }
        .dark .prose table {
            border-color: #334155;
        }
        .prose th {
            background-color: #f8fafc;
            color: #334155;
            font-weight: 600;
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #e2e8f0;
            border-right: 1px solid #e2e8f0;
            text-align: left;
        }
        .dark .prose th {
            background-color: #0f172a;
            color: #cbd5e1;
            border-color: #334155;
        }
        .prose td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #e2e8f0;
            border-right: 1px solid #e2e8f0;
            color: inherit;
        }
        .dark .prose td {
            border-color: #334155;
        }
        .prose th:last-child, .prose td:last-child {
            border-right: 0;
        }
        .prose tr:last-child td {
            border-bottom: 0;
        }
        .prose tr:nth-child(even) {
            background-color: #fbfcfe;
        }
        .dark .prose tr:nth-child(even) {
            background-color: #1e293b/30;
        }
        
        /* Interactive Tree Styles */
        .tree-node-line {
            position: absolute; left: -16px; top: 14px; width: 14px; border-top: 2px solid #e2e8f0;
        }
        .dark .tree-node-line { border-top-color: #334155; }
        .tree-children {
            position: relative; padding-left: 24px; margin-left: 12px; border-left: 2px solid #e2e8f0;
        }
        .dark .tree-children { border-left-color: #334155; }

        /* Transitions */
        .panel-transition { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), width 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        
        /* Loading Dots */
        .typing-dot { animation: typing 1.4s infinite ease-in-out both; }
        .typing-dot:nth-child(1) { animation-delay: -0.32s; }
        .typing-dot:nth-child(2) { animation-delay: -0.16s; }
        @keyframes typing { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
        
        /* Resizer Handles */
        .resizer {
            width: 4px;
            cursor: col-resize;
            background-color: transparent;
            z-index: 30;
            transition: background-color 0.2s;
        }
        .resizer:hover, .resizer.is-resizing {
            background-color: #0ea5e9;
        }
        
        /* Ensure panels can be resized smoothly */
        #leftPanel, #rightPanel {
            flex-shrink: 0;
            will-change: width;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 dark:bg-slate-900 dark:text-slate-200 h-screen w-screen flex flex-col overflow-hidden transition-colors duration-200">

    <header class="h-14 border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 flex items-center justify-between px-4 shrink-0 z-20 relative shadow-sm">
        <div class="flex items-center gap-3">
            <button id="toggleLeftBtn" class="p-1.5 rounded-md hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-slate-600 dark:text-slate-300" title="Toggle Documents">
                <i class="ph ph-list text-xl"></i>
            </button>
            <div class="flex items-center gap-2">
                <div class="w-7 h-7 flex items-center justify-center">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                        <path d="M12 2L2 19H22L12 2Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" class="text-brand-600 dark:text-brand-500"/>
                        <path d="M12 2V19" stroke="currentColor" stroke-width="2" stroke-linejoin="round" class="text-brand-400 dark:text-brand-300"/>
                        <path d="M2 19L12 12L22 19" stroke="currentColor" stroke-width="2" stroke-linejoin="round" class="text-brand-500 dark:text-brand-400"/>
                    </svg>
                </div>
                <h1 class="font-semibold tracking-tight text-lg">Prism <span class="text-xs font-normal text-slate-500 dark:text-slate-400 ml-1 border border-slate-200 dark:border-slate-700 rounded px-1.5 py-0.5 hidden sm:inline-block">Business Intelligence</span></h1>
            </div>
        </div>
        
        <div class="flex items-center gap-4">
            <div class="flex items-center gap-2 text-sm bg-slate-100 dark:bg-slate-800 px-3 py-1.5 rounded-full border border-slate-200 dark:border-slate-700">
                <div id="apiStatusIndicator" class="w-2 h-2 rounded-full bg-slate-400"></div>
                <span id="apiStatusText" class="text-slate-500 dark:text-slate-400 text-xs font-medium">Disconnected</span>
            </div>
            <button id="themeToggleBtn" class="p-1.5 rounded-md hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-slate-500 dark:text-slate-400">
                <i class="ph ph-moon text-xl" id="themeIcon"></i>
            </button>
            <button id="toggleRightBtn" class="p-1.5 rounded-md hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-slate-600 dark:text-slate-300" title="Toggle Chat">
                <i class="ph ph-chat-centered-text text-xl"></i>
            </button>
        </div>
    </header>

    <main class="flex-1 flex overflow-hidden relative">
        
        <!-- LEFT PANEL: Document Management -->
        <aside id="leftPanel" style="width: 288px;" class="border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 flex flex-col panel-transition absolute inset-y-0 left-0 z-10 md:relative md:translate-x-0 -translate-x-full overflow-hidden">
            <div class="p-4 border-b border-slate-200 dark:border-slate-800">
                <h2 class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-3">Knowledge Base</h2>
                <label for="fileUpload" class="flex flex-col items-center justify-center w-full h-24 border-2 border-slate-300 dark:border-slate-700 border-dashed rounded-lg cursor-pointer bg-slate-50 dark:bg-slate-900 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                    <div class="flex flex-col items-center justify-center pt-5 pb-6">
                        <i class="ph ph-upload-simple text-slate-500 mb-2 text-xl"></i>
                        <p class="text-xs text-slate-500 dark:text-slate-400 text-center px-2"><span class="font-semibold text-brand-600">Click to upload</span> commercial documents or reports</p>
                    </div>
                    <input id="fileUpload" type="file" class="hidden" accept="application/pdf" multiple />
                </label>
            </div>
            <div class="flex-1 overflow-y-auto p-2" id="documentList">
                <div class="text-center p-4 text-sm text-slate-500 dark:text-slate-400 italic mt-4" id="emptyDocsMsg">
                    No documents uploaded yet.
                </div>
            </div>
        </aside>

        <!-- Left Resizer -->
        <div id="leftResizer" class="resizer hidden md:block absolute left-[288px] top-0 bottom-0" style="transform: translateX(-50%);"></div>

        <!-- CENTER PANEL: Content Viewer & Reordered Tabs -->
        <section id="centerPanel" class="flex-1 flex flex-col bg-slate-50 dark:bg-slate-900 min-w-0 z-0">
            <div class="border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 px-3 flex overflow-x-auto shrink-0 custom-scrollbar shadow-sm">
                <div class="flex space-x-1.5 py-2.5" id="tabContainer">
                    
                    <!-- 1. Document Viewer -->
                    <button data-tab="viewer" class="tab-btn px-3.5 py-1.5 text-xs font-semibold rounded-full text-brand-600 bg-brand-50 dark:bg-brand-950/40 border border-brand-200/50 dark:border-brand-900/30 transition-all whitespace-nowrap flex items-center gap-2 shadow-sm">
                        <span class="w-5 h-5 rounded-full bg-brand-100 dark:bg-brand-900 flex items-center justify-center"><i class="ph ph-file-pdf"></i></span> Document
                    </button>
                    
                    <!-- 2. Dashboard -->
                    <button data-tab="dashboard" class="tab-btn px-3.5 py-1.5 text-xs font-semibold rounded-full text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900 border border-slate-200/40 dark:border-slate-800/50 transition-all whitespace-nowrap flex items-center gap-2 shadow-sm">
                        <span class="w-5 h-5 rounded-full bg-emerald-100 dark:bg-emerald-950/40 text-emerald-600 flex items-center justify-center"><i class="ph ph-chart-line-up"></i></span> Dashboard
                    </button>

                    <!-- 3. Business Insight Map -->
                    <button data-tab="insight" class="tab-btn px-3.5 py-1.5 text-xs font-semibold rounded-full text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900 border border-slate-200/40 dark:border-slate-800/50 transition-all whitespace-nowrap flex items-center gap-2 shadow-sm">
                        <span class="w-5 h-5 rounded-full bg-sky-100 dark:bg-sky-950/40 text-sky-600 flex items-center justify-center"><i class="ph ph-tree-structure"></i></span> Insight Map
                    </button>

                    <!-- 4. Report Builder -->
                    <button data-tab="report" class="tab-btn px-3.5 py-1.5 text-xs font-semibold rounded-full text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900 border border-slate-200/40 dark:border-slate-800/50 transition-all whitespace-nowrap flex items-center gap-2 shadow-sm">
                        <span class="w-5 h-5 rounded-full bg-cyan-100 dark:bg-cyan-950/40 text-cyan-600 flex items-center justify-center"><i class="ph ph-article"></i></span> Report
                    </button>

                    <!-- 5. SWOT Matrix -->
                    <button data-tab="swot" class="tab-btn px-3.5 py-1.5 text-xs font-semibold rounded-full text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900 border border-slate-200/40 dark:border-slate-800/50 transition-all whitespace-nowrap flex items-center gap-2 shadow-sm">
                        <span class="w-5 h-5 rounded-full bg-rose-100 dark:bg-rose-950/40 text-rose-600 flex items-center justify-center"><i class="ph ph-target"></i></span> SWOT
                    </button>

                    <!-- 6. Deck Generator -->
                    <button data-tab="deck" class="tab-btn px-3.5 py-1.5 text-xs font-semibold rounded-full text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900 border border-slate-200/40 dark:border-slate-800/50 transition-all whitespace-nowrap flex items-center gap-2 shadow-sm">
                        <span class="w-5 h-5 rounded-full bg-violet-100 dark:bg-violet-950/40 text-violet-600 flex items-center justify-center"><i class="ph ph-presentation-chart"></i></span> Deck Gen
                    </button>

                    <!-- 7. Recommendations -->
                    <button data-tab="recommend" class="tab-btn px-3.5 py-1.5 text-xs font-semibold rounded-full text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900 border border-slate-200/40 dark:border-slate-800/50 transition-all whitespace-nowrap flex items-center gap-2 shadow-sm">
                        <span class="w-5 h-5 rounded-full bg-amber-100 dark:bg-amber-950/40 text-amber-600 flex items-center justify-center"><i class="ph ph-lightbulb"></i></span> Recommendations
                    </button>

                    <!-- 8. Audio summary / Podcast -->
                    <button data-tab="audio" class="tab-btn px-3.5 py-1.5 text-xs font-semibold rounded-full text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900 border border-slate-200/40 dark:border-slate-800/50 transition-all whitespace-nowrap flex items-center gap-2 shadow-sm">
                        <span class="w-5 h-5 rounded-full bg-purple-100 dark:bg-purple-950/40 text-purple-600 flex items-center justify-center"><i class="ph ph-headphones"></i></span> Audio Brief
                    </button>

                </div>
            </div>

            <!-- Content Area -->
            <div class="flex-1 overflow-auto relative p-4 md:p-6" id="mainContentArea">
                
                <!-- PDF Canvas-Based Viewer Tab -->
                <div id="tab-viewer" class="tab-content h-full w-full rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-sm bg-white dark:bg-slate-950 flex flex-col">
                    <div id="pdfControls" class="hidden w-full border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 px-4 py-2.5 flex items-center justify-between shrink-0">
                        <div class="flex items-center gap-2 overflow-hidden mr-2">
                            <i class="ph ph-file-text text-brand-500 text-lg shrink-0"></i>
                            <span class="text-xs font-semibold text-slate-600 dark:text-slate-300 truncate max-w-[200px]" id="currentViewerDocName">No document active</span>
                        </div>
                        <div class="flex items-center gap-1 shrink-0">
                            <button id="zoomOutBtn" class="p-1.5 rounded hover:bg-slate-200 dark:hover:bg-slate-800 transition-colors text-slate-600 dark:text-slate-400" title="Zoom Out">
                                <i class="ph ph-minus text-base"></i>
                            </button>
                            <span id="zoomPercent" class="text-xs font-semibold px-2 min-w-[50px] text-center text-slate-600 dark:text-slate-300">200%</span>
                            <button id="zoomInBtn" class="p-1.5 rounded hover:bg-slate-200 dark:hover:bg-slate-800 transition-colors text-slate-600 dark:text-slate-400" title="Zoom In">
                                <i class="ph ph-plus text-base"></i>
                            </button>
                            <div class="w-px h-4 bg-slate-300 dark:bg-slate-700 mx-1.5"></div>
                            <button id="zoomResetBtn" class="p-1.5 rounded hover:bg-slate-200 dark:hover:bg-slate-800 transition-colors text-slate-600 dark:text-slate-400 flex items-center gap-1 text-xs font-medium" title="Reset Zoom">
                                <i class="ph ph-arrows-counter-clockwise text-sm"></i> Reset
                            </button>
                        </div>
                    </div>

                    <div class="flex-1 w-full overflow-y-auto flex flex-col items-center justify-center bg-slate-100 dark:bg-slate-900/40 relative">
                        <div id="noPdfMessage" class="text-slate-400 flex flex-col items-center gap-2 absolute">
                            <i class="ph ph-file-dashed text-4xl"></i>
                            <p class="font-medium text-sm">Select a document to view</p>
                        </div>
                        <div id="pdfCanvasContainer" class="w-full h-full overflow-y-auto hidden p-4 sm:p-6 flex flex-col items-center gap-8"></div>
                    </div>
                </div>

                <!-- Generic Content Container for AI Generated Tabs -->
                <div id="tab-ai-content" class="tab-content hidden max-w-4xl mx-auto w-full pb-12">
                    
                    <!-- Unified Tab Export Header Button -->
                    <div class="flex justify-end mb-4">
                        <button id="globalTabDownloadBtn" class="px-3.5 py-1.8 bg-brand-500 hover:bg-brand-600 text-white rounded-lg text-xs font-semibold flex items-center gap-2 shadow-sm transition-colors hidden">
                            <i class="ph ph-download-simple"></i> Download/Export Output
                        </button>
                    </div>

                    <div id="aiLoadingState" class="hidden flex-col items-center justify-center py-20">
                        <div class="flex space-x-2 mb-4">
                            <div class="w-3 h-3 bg-brand-500 rounded-full typing-dot"></div>
                            <div class="w-3 h-3 bg-brand-500 rounded-full typing-dot"></div>
                            <div class="w-3 h-3 bg-brand-500 rounded-full typing-dot"></div>
                        </div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 animate-pulse" id="loadingText">Analyzing documents...</p>
                    </div>

                    <!-- Dashboard Tab -->
                    <div id="dashboardContainer" class="hidden w-full space-y-6">
                        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4" id="dashKpis"></div>
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6" id="dashCharts"></div>
                        <div class="bg-white dark:bg-slate-950 p-6 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800" id="dashInsights"></div>
                    </div>

                    <!-- Business Insight Map (Professional Minimally Colorful Interactive Tree) -->
                    <div id="insightMapContainer" class="hidden w-full bg-white dark:bg-slate-950 p-8 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                        <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 pb-4 mb-6">
                            <div>
                                <h3 class="text-base font-semibold text-slate-900 dark:text-white">Business Insight Map</h3>
                                <p class="text-xs text-slate-500 dark:text-slate-400">Hierarchical visual diagram of categorized key metrics</p>
                            </div>
                        </div>
                        <div id="insightTreeRoot" class="space-y-4"></div>
                    </div>

                    <!-- Deck Generator Presentation Interface -->
                    <div id="deckContainer" class="hidden w-full space-y-6">
                        <!-- Style Switcher -->
                        <div class="bg-white dark:bg-slate-950 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-wrap items-center justify-between gap-3">
                            <div class="flex items-center gap-2">
                                <i class="ph ph-palette text-violet-500 text-lg"></i>
                                <span class="text-xs font-semibold text-slate-600 dark:text-slate-300">Choose Presentation Theme Style:</span>
                            </div>
                            <div class="flex items-center gap-2" id="deckStyleSelector">
                                <button data-style="corporate" class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-brand-500 text-white border border-transparent transition-colors">Corporate Executive</button>
                                <button data-style="startup" class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-transparent hover:border-slate-300 dark:hover:border-slate-700 transition-colors">Modern Startup</button>
                                <button data-style="analytics" class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-transparent hover:border-slate-300 dark:hover:border-slate-700 transition-colors">Data Analytics</button>
                            </div>
                        </div>
                        <div id="deckSlidesList" class="space-y-6"></div>
                    </div>

                    <!-- Recommendations (Expandable Cards Interface) -->
                    <div id="recommendContainer" class="hidden w-full space-y-4"></div>

                    <!-- SWOT matrix 2x2 Layout -->
                    <div id="swotContainer" class="hidden w-full bg-white dark:bg-slate-950 p-6 sm:p-8 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6" id="swotMatrixGrid"></div>
                    </div>

                    <!-- Audio Report Conversational Script + Synthesizer Player -->
                    <div id="audioBriefContainer" class="hidden w-full space-y-6">
                        <div class="bg-white dark:bg-slate-950 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col md:flex-row items-center justify-between gap-4">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400 flex items-center justify-center shrink-0">
                                    <i class="ph ph-microphone-stage text-2xl animate-pulse"></i>
                                </div>
                                <div>
                                    <h3 class="font-bold text-slate-900 dark:text-white text-base">Analytical Audio Brief</h3>
                                    <p class="text-xs text-slate-500 dark:text-slate-400">Host dialogue containing an exchange with female Lead Analyst</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-2">
                                <button id="playPodcastBtn" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white font-semibold text-xs rounded-lg flex items-center gap-2 shadow-md transition-colors">
                                    <i class="ph-bold ph-play"></i> Play Brief
                                </button>
                                <button id="stopPodcastBtn" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 font-semibold text-xs rounded-lg flex items-center gap-2 shadow-md transition-colors hidden">
                                    <i class="ph-bold ph-stop"></i> Stop
                                </button>
                            </div>
                        </div>
                        <div class="bg-white dark:bg-slate-950 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm" id="podcastScriptBody"></div>
                    </div>

                    <!-- General Analytical tab container (used for standard report formatting) -->
                    <div id="aiContentContainer" class="prose dark:prose-invert max-w-none w-full bg-white dark:bg-slate-950 p-8 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800 hidden">
                        <!-- Content injected here -->
                    </div>
                </div>

            </div>
        </section>

        <!-- Right Resizer -->
        <div id="rightResizer" class="resizer hidden md:block absolute right-[320px] top-0 bottom-0" style="transform: translateX(50%);"></div>

        <!-- RIGHT PANEL: Chat Interface -->
        <aside id="rightPanel" style="width: 320px;" class="border-l border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 flex flex-col panel-transition absolute inset-y-0 right-0 z-10 md:relative md:translate-x-0 translate-x-full shadow-xl md:shadow-none overflow-hidden">
            
            <div class="p-4 border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950">
                <div class="flex flex-col gap-2">
                    <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider flex justify-between items-center">
                        API Connection
